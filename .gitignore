# Generated by theme/theme-switch.sh — local, machine-specific theme selection
hypr/theme.conf
hypr/lock-wallpaper
kitty/theme.conf
rofi/theme-colors.rasi
swaync/theme.css
waybar/theme.css
theme/current

# Generated by install.sh — per-machine waybar module selection
# (battery module shown on laptops, hidden on desktops)
waybar/host.jsonc

# Rewritten by fish itself at runtime. config.fish already declares the only
# thing this held (fish_add_path $HOME/.local/bin), and the -m flag reorders
# the entries on every shell start, so tracking it is pure diff noise.
fish/fish_variables

# Claude Code project directory — local agent state, not config
.claude/
